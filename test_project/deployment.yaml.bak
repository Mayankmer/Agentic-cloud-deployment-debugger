apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-buggy-deployment
  labels:
    app: web
spec:
  replicas: 1
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
      - name: nginx-container
        # INTENTIONAL BUG: This image does not exist
        image: nginx:typo
        ports:
        - containerPort: 80
